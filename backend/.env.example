# Copy this file to .env and fill in your values
# Never commit the real .env file

# PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5433/mcp_factory

# JWT — generate strong secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_STRONG_SECRET

# MinIO (public-facing, for presigned URL generation)
PUBLIC_MINIO_HOST=localhost
PUBLIC_MINIO_PORT=9000
